# Helm dependency tarballs (fetched by helm dep update)
data-platform/charts/*.tgz

# macOS
.DS_Store

# Claude Code session files (exclude agent definitions which should be shared)
.claude/
!.claude/agents/

# Environment files — never commit secrets
.env
*.env
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Uploads (runtime data)
apps/*/uploads/

# Superpowers agent runtime
.superpowers/
