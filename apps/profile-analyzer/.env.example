# ── Ollama (local model server) ───────────────────────────────────────────────
# When running via docker-compose this is set automatically to http://ollama:11434
# For local dev (without Docker) point to your running Ollama instance:
OLLAMA_URL=http://localhost:11434

# Model names — these are pulled automatically on first boot
# Vision model (for dating profile screenshots):
VISION_MODEL=minicpm-v
# Text model (for LinkedIn analysis, resume optimization, job Q&A):
TEXT_MODEL=glm4

# Lighter alternatives if you have limited RAM/VRAM:
#   VISION_MODEL=llava:7b
#   TEXT_MODEL=qwen2.5:3b

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# Export your li_at cookie from browser DevTools → Application → Cookies → linkedin.com
LINKEDIN_LI_AT_COOKIE=

# ── App settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
