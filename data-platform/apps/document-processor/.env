APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Local dev: localhost  |  Docker Compose: chromadb  |  Kubernetes: chromadb (service name)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=documents

SQLITE_PATH=./data/documents.db

# Embedding models — must match across all environments (changing model requires re-indexing all documents)
TEXT_MODEL=nomic-ai/nomic-embed-text-v1.5
IMAGE_MODEL=clip-ViT-B-32
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

MAX_WORKERS=50
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Local dev: http://localhost:11434  |  Docker Compose / Kubernetes: http://ollama:11434
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:0.5b
VISION_MODEL=moondream
RAG_CONTEXT_CHUNKS=5
